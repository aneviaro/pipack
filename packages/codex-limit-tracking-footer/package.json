{
  "name": "@aneviaro/pi-codex-limit-tracking-footer",
  "version": "0.1.0",
  "description": "A Pi footer extension for Codex subscription limit tracking.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "codex",
    "subscription",
    "usage"
  ],
  "files": [
    "extensions",
    "assets",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "test": "node --import tsx --test",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./extensions/codex-limit-tracking-footer.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
